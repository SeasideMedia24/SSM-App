# Copy this file to ".env.local" and fill in the real values from your Supabase project
# (Supabase dashboard → Project Settings → API). NEVER commit the filled-in .env.local.
#
# .env.local is gitignored; this *.example file is committed only to document the shape.

# ── Public (safe to expose to the browser) ─────────────────────────────
# Both of these are sent to the client by Next.js because of the NEXT_PUBLIC_ prefix.
# The anon key is meant to be public; Row-Level Security is what actually protects data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Server-only (NEVER expose to the browser) ──────────────────────────
# The service-role key bypasses Row-Level Security. It must only ever be read in
# server-side code (route handlers / server actions). No NEXT_PUBLIC_ prefix on purpose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
