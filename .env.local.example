# Copy this file to ".env.local" and fill in the real values from your Supabase project
# (Supabase dashboard → Project Settings → API). NEVER commit the filled-in .env.local.
#
# .env.local is gitignored; this *.example file is committed only to document the shape.

# ── Public (safe to expose to the browser) ─────────────────────────────
# Both of these are sent to the client by Next.js because of the NEXT_PUBLIC_ prefix.
# The anon key is meant to be public; Row-Level Security is what actually protects data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Server-only (NEVER expose to the browser) ──────────────────────────
# The service-role key bypasses Row-Level Security. It must only ever be read in
# server-side code (route handlers / server actions). No NEXT_PUBLIC_ prefix on purpose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PaePae assistant (Phase 2). Get a key at https://platform.claude.com → Settings → API Keys.
# Server-only — no NEXT_PUBLIC_ prefix, so it never reaches the browser. Used only by
# the /api/paepae/chat route handler.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Calendar sync (Phase 3). From Google Cloud Console → APIs & Services →
# Credentials → OAuth client ID (Web application). Add BOTH redirect URIs:
#   http://localhost:3000/api/google/oauth/callback   (local dev)
#   https://YOUR-DOMAIN/api/google/oauth/callback      (production)
# Server-only — used by the /api/google/oauth routes and the calendar fetcher.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# QuickBooks Online (Slice 3). From the Intuit Developer portal → your app →
# Production keys. Add BOTH redirect URIs on the app:
#   http://localhost:3000/api/quickbooks/oauth/callback   (local dev)
#   https://YOUR-DOMAIN/api/quickbooks/oauth/callback      (production)
# The verifier token comes from the app's Webhooks section (endpoint:
#   https://YOUR-DOMAIN/api/quickbooks/webhook, subscribed to Invoice + Payment).
# Server-only — used by the /api/quickbooks routes and invoice sync.
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=your-webhook-verifier-token
